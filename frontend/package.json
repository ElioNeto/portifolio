{
  "name": "portifolio",
  "version": "1.0.0",
  "scripts": {
    "start": "ng serve --configuration=pt",
    "build": "ng build",
    "build:pt": "ng build --configuration=pt-production",
    "build:en": "ng build --configuration=en-production",
    "build:es": "ng build --configuration=es-production",
    "lint": "ng lint",
    "test": "ng test --watch=false --browsers=ChromeHeadless",
    "extract-i18n": "ng extract-i18n --output-path src/i18n"
  },
  "dependencies": {
    "@angular/animations": "^17.3.0",
    "@angular/common": "^17.3.0",
    "@angular/compiler": "^17.3.0",
    "@angular/core": "^17.3.0",
    "@angular/forms": "^17.3.0",
    "@angular/platform-browser": "^17.3.0",
    "@angular/platform-browser-dynamic": "^17.3.0",
    "@angular/router": "^17.3.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.14.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.3.0",
    "@angular/cli": "^17.3.0",
    "@angular/compiler-cli": "^17.3.0",
    "@types/node": "^20.0.0",
    "typescript": "~5.4.0"
  }
}
