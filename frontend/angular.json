{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "portifolio": {
      "projectType": "application",
      "i18n": {
        "sourceLocale": "pt",
        "locales": {
          "en": {
            "translation": "src/i18n/messages.en.xlf",
            "baseHref": "/en/"
          },
          "es": {
            "translation": "src/i18n/messages.es.xlf",
            "baseHref": "/es/"
          }
        }
      },
      "schematics": {
        "@schematics/angular:component": {
          "standalone": true,
          "changeDetection": "OnPush",
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/portifolio",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.json",
            "assets": ["src/favicon.ico", "src/assets"],
            "styles": ["src/styles.scss"],
            "scripts": []
          },
          "configurations": {
            "pt-production": {
              "localize": ["pt"],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "budgets": [
                { "type": "initial", "maximumWarning": "500kb", "maximumError": "1mb" }
              ]
            },
            "en-production": {
              "localize": ["en"],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false
            },
            "es-production": {
              "localize": ["es"],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false
            },
            "pt": {
              "localize": ["pt"]
            }
          },
          "defaultConfiguration": "pt-production"
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["src/**/*.ts", "src/**/*.html"]
          }
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "buildTarget": "portifolio:build"
          }
        }
      }
    }
  }
}
